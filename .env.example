# Firebase Configuration
# Set these environment variables to override the built-in defaults.
# If not set, the app will use the fallback values in .env (suitable for dev/demo).
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_DATABASE_ID=

# Cloudinary Configuration (for attendance archival)
VITE_CLOUDINARY_CLOUD_NAME=
VITE_CLOUDINARY_UPLOAD_PRESET=
VITE_CLOUDINARY_FOLDER_PREFIX=

# App Configuration
VITE_APP_NAME=KSAS
VITE_APP_URL=http://localhost:5173

# Demo Mode (set to false for production)
# When true, GPS proximity check failures are bypassed while all other security layers remain active.
VITE_DEMO_MODE=true
